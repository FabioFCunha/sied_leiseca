EMAIL_PORT=587
EMAIL_HOST_USER=usuario@seu-dominio.com
EMAIL_HOST_PASSWORD=sua-senha-ou-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=Agenda Educacao OLS <usuario@seu-dominio.com>
AGENDA_REPLY_TO_EMAIL=usuario@seu-dominio.com
